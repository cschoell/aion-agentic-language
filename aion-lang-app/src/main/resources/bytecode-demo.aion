// ── bytecode-demo.aion ────────────────────────────────────────────────────────
// Showcases language features that work through the bytecode compiler + VM.
// Run with: aion-lang-app compile bytecode-demo.aion
//
// Features demonstrated:
//   const, string interp, break, continue, recursion,
//   lambda (map/filter), @on_fail, tuples, named return,
//   deep field assignment, semicolon statement separator,
//   hex / binary / octal literals, underscore digit separators,
//   range expressions (.. exclusive, ..= inclusive),
//   destructuring let (record + tuple), for-tuple-destructure

const GREETING: Str = "Aion bytecode"
const LIMIT: Int = 4
const MAX_BYTE: Int = 0xFF          // 255  — hex literal
const FLAGS: Int    = 0b1010_1010   // 170  — binary literal with separator
const UNIX_RWX: Int = 0o755         // 493  — octal literal
const MILLION: Int  = 1_000_000     // underscore digit separator

// ── Types ──────────────────────────────────────────────────────────────────
type Counter = { label: Str, value: Int }
type Vec2    = { x: Int, y: Int }

// ── Pure functions ─────────────────────────────────────────────────────────
@pure fn factorial(n: Int) -> Int {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

@pure fn square_all(xs: List[Int]) -> List[Int] {
    return xs.map(fn(x: Int) -> Int { return x * x })
}

@pure fn only_even(xs: List[Int]) -> List[Int] {
    return xs.filter(fn(x: Int) -> Bool { return x % 2 == 0 })
}

// ── @on_fail tool ──────────────────────────────────────────────────────────
@tool
@pure
@requires(b != 0)
@on_fail("b must not be zero. Please retry with a non-zero divisor.")
fn safe_div(a: Int, b: Int) -> Int {
    describe "Divides a by b. Safe for agent use."
    return a / b
}

// ── Tuple: split a list at a threshold ────────────────────────────────────
@pure fn split_at(xs: List[Int], threshold: Int) -> (Int, Int) {
    mut lo_count = 0
    mut hi_count = 0
    for n in xs {
        if n <= threshold {
            lo_count = lo_count + 1
        } else {
            hi_count = hi_count + 1
        }
    }
    return (lo_count, hi_count)
}

// ── Named return with @ensures ─────────────────────────────────────────────
@pure
@ensures(clamped >= 0)
fn abs_clamp(n: Int) -> (clamped: Int) {
    return match n {
        x if x < 0 => -x,
        x           => x,
    }
}

@pure fn main() -> Unit {
    // -- const + string interpolation --
    print("Hello from ${GREETING}!")

    // -- break --
    mut i = 0
    while i < 100 {
        i = i + 1
        if i == LIMIT { break }
    }
    print("Broke out at i = ${i}")

    // -- continue: print only odd numbers 1..7 --
    mut j = 0
    while j < 7 {
        j = j + 1
        if j == 2 { continue }
        if j == 4 { continue }
        if j == 6 { continue }
        print("odd: ${j}")
    }

    // -- recursive user function --
    print("5! = ${factorial(5)}")

    // -- arithmetic in interpolation --
    let a = 6
    let b = 7
    print("${a} * ${b} = ${a * b}")

    // -- lambda: map --
    let nums = [1, 2, 3, 4, 5]
    let squares = square_all(nums)
    print("Squares: ${squares}")

    // -- lambda: filter --
    let evens = only_even(nums)
    print("Evens:   ${evens}")

    // -- inline lambda stored in variable --
    let triple = fn(x: Int) -> Int { return x * 3 }
    let tripled = nums.map(triple)
    print("Tripled: ${tripled}")

    // -- @on_fail tool --
    let d = safe_div(20, 4)
    print("safe_div(20, 4) = ${d}")

    // -- tuples --
    let parts = split_at([1, 2, 3, 4, 5, 6], 3)
    print("split_at([1..6], 3): lo=${parts.first()}, hi=${parts.second()}")

    // -- named return --
    print("abs_clamp(-7) = ${abs_clamp(-7)}")
    print("abs_clamp(4)  = ${abs_clamp(4)}")

    // -- deep field assignment --
    mut ctr = Counter { label: "hits", value: 0 }
    ctr.value = 42
    print("counter '${ctr.label}' = ${ctr.value}")

    // -- numeric literals: hex, binary, octal, underscore separator --
    print("MAX_BYTE 0xFF        = ${MAX_BYTE}")
    print("FLAGS    0b1010_1010 = ${FLAGS}")
    print("UNIX_RWX 0o755       = ${UNIX_RWX}")
    print("MILLION  1_000_000   = ${MILLION}")
    let color   = 0xDEAD
    let shifted = color / 0x10
    print("0xDEAD = ${color}, 0xDEAD / 0x10 = ${shifted}")

    // -- semicolon as inline statement separator --
    let p = 3; let q = 4
    print("p + q = ${p + q}")
    mut acc = 0; mut k = 1
    while k <= 5 { acc = acc + k; k = k + 1 }
    print("sum(1..5) = ${acc}")

    // -- range expressions: exclusive (..) and inclusive (..=) --
    mut range_sum = 0
    for n in 1..=10 { range_sum = range_sum + n }
    print("sum(1..=10) = ${range_sum}")
    let digits = 0..5
    print("digits 0..5 = ${digits}")
    mut evens_sum = 0
    for n in 0..10 {
        if n % 2 == 0 { evens_sum = evens_sum + n }
    }
    print("even sum 0..10 = ${evens_sum}")

    // -- destructuring let: record --
    let v = Vec2 { x: 3, y: 4 }
    let { x, y } = v
    print("Vec2 destructure: x=${x}, y=${y}")

    // -- destructuring let: tuple --
    let coords = (10, 20)
    let (cx, cy) = coords
    print("tuple destructure: cx=${cx}, cy=${cy}")

    // -- for-tuple-destructure --
    let pairs = [(1, 100), (2, 200), (3, 300)]
    mut pair_sum = 0
    for (k, v2) in pairs { pair_sum = pair_sum + k + v2 }
    print("pair_sum = ${pair_sum}")
}
