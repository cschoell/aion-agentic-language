// ── Aion sample program ────────────────────────────────────────────────────
//
// Demonstrates the core language features:
//   - type declarations (records) and enums (sum types)
//   - fn with effect annotations
//   - match, Option, Result
//   - pipeline operator |>
//   - named arguments
//   - for / while loops
//
// Features shown:
//   const          — PI, MAX_USERS defined at the top
//   string interp  — "${name}" instead of "Hello, " + name + "!"
//   pattern guards — classify numbers and shapes by condition
//   ?              — error propagation with Result
//   break/continue — early loop control
//   @on_fail       — structured tool errors for agent loops
//   refinement type — Tag = Str where constraint enforced on assignment
//   lambda         — fn(x) -> T used with map / filter

// ── Constants ─────────────────────────────────────────────────────────────

const PI: Float = 3.14159
const MAX_USERS: Int = 10

// ── Refinement types ───────────────────────────────────────────────────────
// The runtime checks these constraints on every assignment.

type PositiveInt = Int   where { self > 0 }
type ShortStr    = Str   where { self.len() <= 20 }

// ── Types ──────────────────────────────────────────────────────────────────

type Point = {
    x: Float,
    y: Float,
}

type User = {
    name: Str,
    age:  Int,
}

enum Shape {
    Circle(Float),
    Rectangle { width: Float, height: Float },
    Triangle(Float, Float, Float),
}

enum Color {
    Red,
    Green,
    Blue,
}

// ── Pure functions ─────────────────────────────────────────────────────────

@pure fn add(a: Int, b: Int) -> Int {
    return a + b
}

// String interpolation instead of concatenation
@pure fn greet(name: Str) -> Str {
    return "Hello, ${name}!"
}

// Pattern guards replace range chains in nested ifs
@pure fn classify_age(age: Int) -> Str {
    return match age {
        n if n < 13  => "child",
        n if n < 18  => "teenager",
        n if n < 65  => "adult",
        _            => "senior",
    }
}

// const PI used directly in expression
@pure fn area(shape: Shape) -> Float {
    return match shape {
        Shape::Circle(r)                   => r * r * PI,
        Shape::Rectangle { width, height } => width * height,
        Shape::Triangle(a, b, c)           => {
            let s = (a + b + c) / 2.0
            let under = s * (s - a) * (s - b) * (s - c)
            under
        },
    }
}

@pure fn color_name(c: Color) -> Str {
    return match c {
        Color::Red   => "red",
        Color::Green => "green",
        Color::Blue  => "blue",
    }
}

// ── Option / Result usage ──────────────────────────────────────────────────

@pure fn safe_divide(a: Float, b: Float) -> Result[Float, Str] {
    if b == 0.0 {
        return err("division by zero")
    }
    return ok(a / b)
}

// ? propagation: if safe_divide returns err, ratio_str returns it immediately
@pure fn ratio_str(a: Float, b: Float) -> Result[Str, Str] {
    let v = safe_divide(a, b)?
    return ok("${a} / ${b} = ${v}")
}

@pure fn find_user(users: List[User], name: Str) -> Option[User] {
    for u in users {
        if u.name == name {
            return some(u)
        }
    }
    return none
}

// ── Tool function with @on_fail ────────────────────────────────────────────
// If score < 0 or score > max, the agent gets a structured error instead of a crash.
@tool
@pure
@requires(score >= 0)
@requires(score <= max)
@on_fail("score must be between 0 and max inclusive.")
fn clamp_score(score: Int, max: Int) -> Int {
    describe "Returns score unchanged. Pre-conditions enforce valid range."
    return score
}

// ── Lambda / higher-order helpers ─────────────────────────────────────────

// square each element — lambda passed to map
@pure fn square_all(xs: List[Int]) -> List[Int] {
    return xs.map(fn(x: Int) -> Int { return x * x })
}

// keep only elements above a threshold — lambda passed to filter
@pure fn above(xs: List[Int], threshold: Int) -> List[Int] {
    return xs.filter(fn(x: Int) -> Bool { return x > threshold })
}

// ── Pipeline helpers ───────────────────────────────────────────────────────

@pure fn double_val(x: Int) -> Int { return x * 2 }
@pure fn increment(x: Int)  -> Int { return x + 1 }

// ── Entry point ────────────────────────────────────────────────────────────

@io fn main() -> Unit {

    // -- Basic arithmetic with string interpolation --
    let result = add(a: 3, b: 4)
    print("3 + 4 = ${result}")

    // -- Greeting using interp --
    let msg = greet(name: "Aion")
    print(msg)

    // -- Pattern guard: age classification --
    print("Age 10 is a ${classify_age(10)}")
    print("Age 16 is a ${classify_age(16)}")
    print("Age 35 is an ${classify_age(35)}")
    print("Age 70 is a ${classify_age(70)}")
    print("")

    // -- Enum + match with const PI --
    let c = Shape::Circle(5.0)
    let r = Shape::Rectangle { width: 4.0, height: 6.0 }
    print("Circle area:    ${area(shape: c)}")
    print("Rectangle area: ${area(shape: r)}")
    print("Favourite color: ${color_name(c: Color::Red)}")
    print("")

    // -- Result with ? propagation --
    match ratio_str(10.0, 3.0) {
        ok(s)  => print(s),
        err(e) => print("Error: ${e}"),
    }
    match ratio_str(5.0, 0.0) {
        ok(s)  => print(s),
        err(e) => print("Caught: ${e}"),
    }
    print("")

    // -- Refinement types --
    // PositiveInt constraint: any assignment of a non-positive value would fail
    let p: PositiveInt = 42
    print("PositiveInt p = ${p}")
    // ShortStr constraint: strings up to 20 chars are accepted
    let tag: ShortStr = "aion-agent-v1"
    print("ShortStr tag  = ${tag}")
    print("")

    // -- Lambda: map and filter --
    let nums = [1, 2, 3, 4, 5]
    let squares = square_all(nums)
    print("Squares:   ${squares}")
    let big = above(nums, 3)
    print("Above 3:   ${big}")

    // inline lambda stored in a variable and called directly
    let triple = fn(x: Int) -> Int { return x * 3 }
    let tripled = nums.map(triple)
    print("Tripled:   ${tripled}")
    print("")

    // -- @on_fail tool: valid call succeeds --
    let cs = clamp_score(7, 10)
    print("clamp_score(7, 10) = ${cs}")
    print("")

    // -- List + break + continue --
    mut numbers = [1, 2, 3, 4, 5]
    numbers.push(6)

    // Sum only even numbers; stop if we see a number > 5
    mut even_sum = 0
    for n in numbers {
        if n > 5 { break }
        if n == 3 { continue }
        if n == 2 { even_sum = even_sum + n }
        if n == 4 { even_sum = even_sum + n }
    }
    print("Even sum (2+4, skipping 3, stopping at 6): ${even_sum}")

    // -- Pipeline: 3 |> double_val |> increment == 7 --
    let piped = 3 |> double_val |> increment
    print("Pipeline 3 |> double |> inc = ${piped}")
    print("")

    // -- While loop with MAX_USERS const --
    mut count = 0
    while count < MAX_USERS {
        count = count + 1
        if count == 3 { break }
    }
    print("Counted to ${count} (limit was ${MAX_USERS})")
    print("")

    // -- User lookup with interp in match arms --
    let users = [
        User { name: "Alice", age: 30 },
        User { name: "Bob",   age: 25 },
    ]
    match find_user(users: users, name: "Alice") {
        some(u) => print("Found ${u.name}, who is a ${classify_age(u.age)}"),
        none    => print("Not found"),
    }
    match find_user(users: users, name: "Eve") {
        some(u) => print("Found ${u.name}"),
        none    => print("Eve not found"),
    }
}

