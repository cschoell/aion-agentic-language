// ── agent-tools.aion ──────────────────────────────────────────────────────────
//
// Demonstrates the AI-agent safety features of Aion:
//
//   @tool        — marks a function as callable by an AI agent
//   @requires    — pre-condition checked before the body runs
//   @ensures     — post-condition checked after the body returns (binds `result`)
//   @on_fail     — wraps any tool failure as err(ToolError{hint,cause}) for agents
//   @timeout     — maximum execution time in milliseconds
//   @untrusted   — declares that all inputs arrive from an external / agent source
//   describe     — inline doc-string embedded in the function (shown in JSON descriptor)
//   assert       — runtime-checked invariant with an explanatory message
//
// Features used here:
//   const          — shared limits / messages defined once
//   string interp  — "You got ${score} / ${TOTAL}" instead of concatenation
//   pattern guards — match score { n if n == TOTAL => ... }
//   ?              — error propagation in parse_int_answer
//   break          — quiz loop exits cleanly when user types "quit"
//   @on_fail       — structured error hints for agent self-correction
//   refinement type — Score = Int where { self >= 0 and self <= TOTAL }
//   lambda         — fn(a: Str) -> Str passed to normalise answers
//
// Tuples and records demonstrate compound data:
//   (Int, Int)     — quiz_result tuple for score and total
//   { ... }        — QuizStats record tracks attempts and correct answers

const TOTAL: Int = 3
const BORDER: Str = "+======================================+"

// ── Types ──────────────────────────────────────────────────────────────────
type QuizStats = { attempts: Int, correct: Int }

// ── Refinement type: Score always in [0, TOTAL] ────────────────────────────
// The runtime checks this constraint on every assignment.
type Score = Int where { self >= 0 and self <= 3 }

// ── Arithmetic tool ────────────────────────────────────────────────────────
@tool
@pure
@requires(b != 0)
@ensures(result * b == a - a % b)
@on_fail("b must not be zero. Please retry with a non-zero divisor.")
fn safe_div(a: Int, b: Int) -> Int {
    describe "Divides a by b. Requires b != 0. Safe for agent use."
    return a / b
}

// ── String sanitiser tool ──────────────────────────────────────────────────
@tool
@io
@untrusted
@timeout(500)
@requires(raw_input != "")
@on_fail("Input was empty or blank. Please provide a non-whitespace string.")
fn sanitise(raw_input: Str) -> Str {
    describe "Trims whitespace from agent-supplied input."
    let trimmed = raw_input.trim()
    assert trimmed != "", "Input must not be blank after trimming"
    return trimmed
}

// ── Scoring tool — named return so @ensures is self-documenting ─────────────
@tool
@pure
@requires(score >= 0)
@requires(score <= total)
@ensures(next_score >= 0)
@ensures(next_score <= total)
@on_fail("Score out of range. score must be in [0, total].")
fn award_point(score: Int, total: Int, correct: Bool) -> (next_score: Int) {
    describe "Awards one point when correct is true."
    if correct { return score + 1 }
    return score
}

// ── Answer normaliser — lambda pipeline ────────────────────────────────────
@pure fn normalise(answer: Str) -> Str {
    let steps = [
        fn(s: Str) -> Str { return s.trim() },
        fn(s: Str) -> Str { return s.lower() },
    ]
    mut out = answer
    for step in steps {
        out = step(out)
    }
    return out
}

// ── Verdict helper — pattern guards ───────────────────────────────────────
@pure fn verdict(score: Int) -> Str {
    return match score {
        n if n == TOTAL => "PERFECT SCORE!  You got ${n} / ${TOTAL}.",
        n if n >= 2     => "Good job!  You got ${n} / ${TOTAL}.",
        n if n == 1     => "You got 1 / ${TOTAL}.  Keep studying!",
        _               => "You got 0 / ${TOTAL}.  Better luck next time!",
    }
}

// ── Return quiz result as a tuple ────────────────────────────────────────────
@pure fn quiz_result(score: Int, total: Int) -> (Int, Int) {
    return (score, total)
}

// ── Main: interactive quiz ─────────────────────────────────────────────────
@io fn main() -> Unit {
    print(BORDER)
    print("|   Aion Agent-Safe Quiz  (mode: interp)|")
    print(BORDER)
    print("")
    print("Type 'quit' at any question to exit early.")
    print("")

    mut score: Score = 0
    mut done = false

    // Deep field assignment — track attempts/correct counts in a record
    mut stats = QuizStats { attempts: 0, correct: 0 }

    // ── Q1 — safe_div sanity-check ────────────────────────────────────────────
    while not done {
        print("Q1: What is 10 / 2?")
        let a1 = sanitise(input())
        if normalise(a1) == "quit" { done = true; break
                }
        let v1 = safe_div(10, 2)
        assert v1 == 5, "safe_div sanity check"
        stats.attempts = stats.attempts + 1
        if normalise(a1) == "5" {
            score = award_point(score, TOTAL, true)
            stats.correct = stats.correct + 1
            print("  [CORRECT]  (verified via safe_div: ${v1})")
        } else {
            score = award_point(score, TOTAL, false)
            print("  [WRONG]  The answer is 5.")
        }
        print("")
        break
    }

    // ── Q2 — geography ────────────────────────────────────────────────────────
    while not done {
        print("Q2: What is the capital of France?")
        let a2 = sanitise(input())
        if normalise(a2) == "quit" {
            done = true
            break
        }
        stats.attempts = stats.attempts + 1
        if normalise(a2) == "paris" {
            score = award_point(score, TOTAL, true)
            stats.correct = stats.correct + 1
            print("  [CORRECT]")
        } else {
            score = award_point(score, TOTAL, false)
            print("  [WRONG]  The answer is Paris.")
        }
        print("")
        break
    }

    // ── Q3 — multiplication ───────────────────────────────────────────────────
    while not done {
        print("Q3: What is 7 * 6?")
        let a3 = sanitise(input())
        if normalise(a3) == "quit" {
            done = true
            break
        }
        stats.attempts = stats.attempts + 1
        if normalise(a3) == "42" {
            score = award_point(score, TOTAL, true)
            stats.correct = stats.correct + 1
            print("  [CORRECT]")
        } else {
            score = award_point(score, TOTAL, false)
            print("  [WRONG]  The answer is 42.")
        }
        print("")
        break
    }

    if not done {
        let res = quiz_result(score, TOTAL)
        print(BORDER)
        print("  ${verdict(res.first())}")
        print(BORDER)
    }
}
